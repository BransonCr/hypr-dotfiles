# dunst — rose-pine
[global]
    monitor = 0
    follow = mouse
    width = 340
    height = (0, 200)
    origin = top-right
    offset = (12, 12)
    scale = 0
    notification_limit = 6

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_corner_radius = 4

    indicate_hidden = yes
    transparency = 5
    separator_height = 2
    padding = 12
    horizontal_padding = 14
    frame_width = 2
    corner_radius = 12
    gap_size = 6

    font = JetBrainsMono Nerd Font 11
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48

    mouse_left_click = do_action, close_current
    mouse_right_click = close_all
    mouse_middle_click = close_current

[urgency_low]
    background = "#1f1d2e"
    foreground = "#908caa"
    frame_color = "#26233a"
    timeout = 5

[urgency_normal]
    background = "#1f1d2e"
    foreground = "#e0def4"
    frame_color = "#c4a7e7"
    timeout = 8

[urgency_critical]
    background = "#1f1d2e"
    foreground = "#e0def4"
    frame_color = "#eb6f92"
    timeout = 0
